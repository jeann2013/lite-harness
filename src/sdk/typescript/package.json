{
  "name": "@lite-harness/sdk",
  "version": "0.1.0",
  "description": "Drop-in replacement for the Claude Agent SDK that talks to a lite-harness server over JSON-RPC stdio.",
  "type": "module",
  "license": "MIT",
  "author": "lite-harness",
  "keywords": [
    "claude",
    "agent",
    "sdk",
    "lite-harness",
    "llm"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.161",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
